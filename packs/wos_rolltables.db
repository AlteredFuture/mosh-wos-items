{"_id":"WoSLoadoutTeamst","name":"Wages of Sin Loadout - Teamsters","img":"modules/fvtt_mosh_1e_psg/icons/rolltables/loadouts.png","description":"<p>Your <strong>Loadout</strong> contains the weapons, armor, and other gear you start with. Some are better than others, but all of them are useful in the hands of a desperate person.</p>","formula":"1d10-1","replacement":true,"displayRoll":true,"results":[{"_id":"wosR0582d68ef1","type":"document","name":"Utility Jumpsuit","img":"modules/fvtt_mosh_1e_psg/icons/armor/heavy_duty_work_clothes.png","documentUuid":"Compendium.mosh-wos-items.wos_armor.Item.wosArmr34a3ce8c0","weight":1,"range":[0,0],"drawn":false},{"_id":"wosRadcef5649f","type":"document","name":"Assorted Tools","img":"modules/fvtt_mosh_1e_psg/icons/equipment/assorted_tools.png","documentUuid":"Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.H3tGGe3I8lzbP8bS","weight":1,"range":[0,0],"drawn":false},{"_id":"wosR9d65b0f709","type":"document","name":"Bag of Sugar","img":"icons/svg/item-bag.svg","documentUuid":"Compendium.mosh-wos-items.wos_equipment.Item.wosEqp16a49904cd","weight":1,"range":[0,0],"drawn":false},{"_id":"wosR23dc9f953c","type":"document","name":"Crowbar","img":"modules/fvtt_mosh_1e_psg/icons/weapons/crowbar.png","documentUuid":"Compendium.fvtt_mosh_1e_psg.items_weapons_1e.Item.1fpZrZ5uN7Ad9XvX","weight":1,"range":[0,0],"drawn":false},{"_id":"wosR68e035ce64","type":"document","name":"Electromagnet","img":"modules/fvtt_mosh_1e_psg/icons/equipment/battery_high_power.png","documentUuid":"Compendium.mosh-wos-items.wos_equipment.Item.wosEqpe0d065a6c2","weight":1,"range":[0,0],"drawn":false},{"_id":"wosR4b306797bb","type":"document","name":"Vaccsuit","img":"modules/fvtt_mosh_1e_psg/icons/armor/vaccsuit.png","documentUuid":"Compendium.fvtt_mosh_1e_psg.items_armor_1e.Item.MW8GRF9grFvsAGcR","weight":1,"range":[1,1],"drawn":false},{"_id":"wosRcf2a70e0cb","type":"document","name":"Nail Gun","img":"modules/fvtt_mosh_1e_psg/icons/weapons/nail_gun.png","documen