umentId": "GPeQpFIBuQIrKzX0", "text": "Lockpick Set", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/lockpick_set.png", "weight": 1, "range": [8, 8], "drawn": false, "name": "Lockpick Set", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.GPeQpFIBuQIrKzX0"}, {"_id": "wosT08a5", "type": "document", "documentCollection": "fvtt_mosh_1e_psg.items_equipment_1e", "documentId": "uHPFcNQEA0amUJQJ", "text": "Mag-boots", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/mag_boots.png", "weight": 1, "range": [8, 8], "drawn": false, "name": "Mag-boots", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.uHPFcNQEA0amUJQJ"}, {"_id": "wosT09a1", "type": "document", "documentCollection": "fvtt_mosh_1e_psg.items_armor_1e", "documentId": "2NoJYxUEvxCLk58f", "text": "Standard Crew Attire", "img": "modules/fvtt_mosh_1e_psg/icons/armor/standard_crew_attire.png", "weight": 1, "range": [9, 9], "drawn": false, "name": "Standard Crew Attire", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_armor_1e.Item.2NoJYxUEvxCLk58f"}, {"_id": "wosT09a2", "type": "document", "documentCollection": "mosh-wos-items.wos_equipment", "documentId": "WoSEquipObsExoload", "text": "Obsolete Exoloader", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/exoloader.png", "weight": 1, "range": [9, 9], "drawn": false, "name": "Obsolete Exoloader", "documentUuid": "Compendium.mosh-wos-items.wos_equipment.Item.WoSEquipObsExoload"}], "flags": {}, "folder": null, "sort": 400, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}}
{"_id": "WoSPatchBH0001", "name": "Bounty Hunter Patch Table", "img": "icons/svg/d6-grey.svg", "description": "<p>Roll on this table for a Bounty Hunter's starting patch.</p>", "formula": "1d6", "replacement": true, "displayRoll": true, "results": [{"_id": "WoSPTBHR0000001", "type": "document", "text": "Dead or Alive (Preferably Alive) Patch", "weight": 1, "range": [1, 1], "drawn": false, "documentCollection": "mosh-wos-items.wos_patches", "documentId": "WoSPatch00000001", "name": "Dead or Alive (Preferably Alive) Patch", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000001"}, {"_id": "WoSPTBHR0000002", "type": "document", "text": "Warrant Officer Badge (Faded, Unofficial)", "weight": 1, "range": [2, 2], "drawn": false, "documentCollection": "mosh-wos-items.wos_patches", "documentId": "WoSPatch00000002", "name": "Warrant Officer Badge (Faded, Unofficial)", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000002"}, {"_id": "WoSPTBHR0000003", "type": "document", "text": "Colonial Bounty Registry Logo Patch", "weight": 1, "range": [3, 3], "drawn": false, "documentCollection": "mosh-wos-items.wos_patches", "documentId": "WoSPatch00000003", "name": "Colonial Bounty Registry Logo Patch", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000003"}, {"_id": "WoSPTBHR0000004", "type": "document", "text": "I Found Him Patch (Crossed-Out Skull)", "weight": 1, "range": [4, 4], "drawn": false, "documentCollection": "mosh-wos-items.wos_patches", "documentId": "WoSPatch00000004", "name": "I Found Him Patch (Crossed-Out Skull)", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000004"}, {"_id": "WoSPTBHR0000005", "type": "document", "text": "Sector 7 Fugitive Recovery Unit Patch", "weight": 1, "range": [5, 5], "drawn": false, "documentCollection": "mosh-wos-items.wos_patches", "documentId": "WoSPatch00000005", "name": "Sector 7 Fugitive Recovery Unit Patch", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000005"}, {"_id": "WoSPTBHR0000006", "type": "document", "text": "Payment Upon Delivery (Crossed Keys)", "weight": 1, "range": [6, 6], "drawn": false, "documentCollection": "mosh-wos-items.wos_patches", "documentId": "WoSPatch00000006", "name": "Payment Upon Delivery (Crossed Keys)", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000006"}], "flags": {}, "folder": null, "sort": 800, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}}
{"_id": "WoSTableBountyLevel", "name": "Wages of Sin - Bounty Level & Rewards", "img": "icons/svg/d20-black.svg", "description": "<p>Bounty Level & Rewards table from Wages of Sin (pg. 12-13).</p>", "formula": "1d9", "replacement": true, "displayRoll": true, "results": [{"_id": "blr01", "type": "text", "text": "BL:1 - Minor Bounties (Payscale: 1D10KCR) - Minor issues for organizations. Big problems for desperate civilians.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [1, 1], "drawn": false, "name": "BL:1 - Minor Bounties (Payscale: 1D10KCR) - Minor issues for organizations. Big problems for desperate civilians."}, {"_id": "blr02", "type": "text", "text": "BL:2 - Lesser Bounties (Payscale: 1D5X10KCR) - Bounties on people who do not want to be found.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [2, 2], "drawn": false, "name": "BL:2 - Lesser Bounties (Payscale: 1D5X10KCR) - Bounties on people who do not want to be found."}, {"_id": "blr03", "type": "text", "text": "BL:3 - Serious Bounties (Payscale: 1D10X10KCR) - Targets with experience or resources and the will to use them.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [3, 3], "drawn": false, "name": "BL:3 - Serious Bounties (Payscale: 1D10X10KCR) - Targets with experience or resources and the will to use them."}, {"_id": "blr04", "type": "text", "text": "BL:4 - Dangerous Bounties (Payscale: 1D5X100KCR) - Targets with experience and resources. They will kill you.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [4, 4], "drawn": false, "name": "BL:4 - Dangerous Bounties (Payscale: 1D5X100KCR) - Targets with experience and resources. They will kill you."}, {"_id": "blr05", "type": "text", "text": "BL:5 - Major Bounties (Payscale: 1D10X100KCR) - High-power targets or those outside normal social context.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [5, 5], "drawn": false, "name": "BL:5 - Major Bounties (Payscale: 1D10X100KCR) - High-power targets or those outside normal social context."}, {"_id": "blr06", "type": "text", "text": "BL:6 - Operational Bounties (Payscale: 1D5MCR) - Those protected by organized violence.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [6, 6], "drawn": false, "name": "BL:6 - Operational Bounties (Payscale: 1D5MCR) - Those protected by organized violence."}, {"_id": "blr07", "type": "text", "text": "BL:7 - Strategic Bounties (Payscale: 1D10MCR) - The linchpins of organizations or those who wield terrible power directly.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [7, 7], "drawn": false, "name": "BL:7 - Strategic Bounties (Payscale: 1D10MCR) - The linchpins of organizations or those who wield terrible power directly."}, {"_id": "blr08", "type": "text", "text": "BL:8 - Legendary Bounties (Payscale: 2D10MCR) - Household names or those at the secret loci of power.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [8, 8], "drawn": false, "name": "BL:8 - Legendary Bounties (Payscale: 2D10MCR) - Household names or those at the secret loci of power."}, {"_id": "blr09", "type": "text", "text": "BL:9 - Apocalyptic Bounties (Payscale: 1D100MCR) - Names that are only whispered. Senior executives. Rogue AI.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [9, 9], "drawn": false, "name": "BL:9 - Apocalyptic Bounties (Payscale: 1D100MCR) - Names that are only whispered. Senior executives. Rogue AI."}], "flags": {}, "folder": null, "sort": 1000, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}}
{"_id": "WoSTableClientType", "name": "Wages of Sin - Client Type", "img": "icons/svg/d20-black.svg", "description": "<p>Table 20.1 Client Type table from Wages of Sin.</p>", "formula": "1d10", "replacement": true, "displayRoll": true, "results": [{"_id": "wosct01", "type": "text", "text": "Corporate", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [1, 4], "drawn": false, "name": "Corporate"}, {"_id": "wosct02", "type": "text", "text": "Criminal", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [5, 6], "drawn": false, "name": "Criminal"}, {"_id": "wosct03", "type": "text", "text": "Union", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [7, 7], "drawn": false, "name": "Union"}, {"_id": "wosct04", "type": "text", "text": "Civilian", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [8, 8], "drawn": false, "name": "Civilian"}, {"_id": "wosct05", "type": "text", "text": "Military", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [9, 10], "drawn": false, "name": "Military"}], "flags": {}, "folder": null, "sort": 1100, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}}
{"_id": "WoSTableComplications", "name": "Wages of Sin - Complications", "img": "icons/svg/d20-black.svg", "description": "<p>Complications table (d100) from Wages of Sin.</p>", "formula": "1d100", "replacement": true, "displayRoll": true, "results": [{"_id": "woscp001", "type": "text", "text": "There is a family or personal relationship between the client and the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [1, 1], "drawn": false, "name": "There is a family or personal relationship between the client and the target."}, {"_id": "woscp002", "type": "text", "text": "A local authority has imprisoned the target for unrelated crimes.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [2, 2], "drawn": false, "name": "A local authority has imprisoned the target for unrelated crimes."}, {"_id": "woscp003", "type": "text", "text": "The target lives nomadically, with no fixed address.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [3, 3], "drawn": false, "name": "The target lives nomadically, with no fixed address."}, {"_id": "woscp004", "type": "text", "text": "The target has extensive combat training.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [4, 4], "drawn": false, "name": "The target has extensive combat training."}, {"_id": "woscp005", "type": "text", "text": "The target is in an active or imminent war zone.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [5, 5], "drawn": false, "name": "The target is in an active or imminent war zone."}, {"_id": "woscp006", "type": "text", "text": "The target has an extensive network of friends in the area.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [6, 6], "drawn": false, "name": "The target has an extensive network of friends in the area."}, {"_id": "woscp007", "type": "text", "text": "A religious organization protects the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [7, 7], "drawn": false, "name": "A religious organization protects the target."}, {"_id": "woscp008", "type": "text", "text": "The target is not guilty of the crime. They know who is.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [8, 8], "drawn": false, "name": "The target is not guilty of the crime. They know who is."}, {"_id": "woscp009", "type": "text", "text": "The client is attempting to pin a crime on the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [9, 9], "drawn": false, "name": "The client is attempting to pin a crime on the target."}, {"_id": "woscp010", "type": "text", "text": "An unknown force protects the target. They are unaware.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [10, 10], "drawn": false, "name": "An unknown force protects the target. They are unaware."}, {"_id": "woscp011", "type": "text", "text": "The target is embroiled in an unrelated sensitive legal matter which requires their full attention.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [11, 11], "drawn": false, "name": "The target is embroiled in an unrelated sensitive legal matter which requires their full attention."}, {"_id": "woscp012", "type": "text", "text": "The crew already knows the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [12, 12], "drawn": false, "name": "The crew already knows the target."}, {"_id": "woscp013", "type": "text", "text": "The client is many jumps away from the target and requires delivery.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [13, 13], "drawn": false, "name": "The client is many jumps away from the target and requires delivery."}, {"_id": "woscp014", "type": "text", "text": "Other victims pursue the target, seeking revenge for themselves.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [14, 14], "drawn": false, "name": "Other victims pursue the target, seeking revenge for themselves."}, {"_id": "woscp015", "type": "text", "text": "The target is able to morally justify their actions.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [15, 15], "drawn": false, "name": "The target is able to morally justify their actions."}, {"_id": "woscp016", "type": "text", "text": "The target is unaware of their 'crime' or the bounty.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [16, 16], "drawn": false, "name": "The target is unaware of their 'crime' or the bounty."}, {"_id": "woscp017", "type": "text", "text": "The client is using the bounty as cover to pursue an unrelated agenda.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [17, 17], "drawn": false, "name": "The client is using the bounty as cover to pursue an unrelated agenda."}, {"_id": "woscp018", "type": "text", "text": "The target protects themselves with their immense wealth.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [18, 18], "drawn": false, "name": "The target protects themselves with their immense wealth."}, {"_id": "woscp019", "type": "text", "text": "Scant details on the target are available; significant investigative legwork is required.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [19, 19], "drawn": false, "name": "Scant details on the target are available; significant investigative legwork is required."}, {"_id": "woscp020", "type": "text", "text": "The target has many dependents.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [20, 20], "drawn": false, "name": "The target has many dependents."}, {"_id": "woscp021", "type": "text", "text": "The bounty has a strict, short time limit.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [21, 21], "drawn": false, "name": "The bounty has a strict, short time limit."}, {"_id": "woscp022", "type": "text", "text": "The lives of bystanders mean nothing to the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [22, 22], "drawn": false, "name": "The lives of bystanders mean nothing to the target."}, {"_id": "woscp023", "type": "text", "text": "Something inhuman pursues the target. It will not allow others to seize its quarry.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [23, 23], "drawn": false, "name": "Something inhuman pursues the target. It will not allow others to seize its quarry."}, {"_id": "woscp024", "type": "text", "text": "Prophetic visions plague the target. These visions are infectious, spreading to any in close physical proximity.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [24, 24], "drawn": false, "name": "Prophetic visions plague the target. These visions are infectious, spreading to any in close physical proximity."}, {"_id": "woscp025", "type": "text", "text": "The target is willing to trade valuable information for their freedom.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [25, 25], "drawn": false, "name": "The target is willing to trade valuable information for their freedom."}, {"_id": "woscp026", "type": "text", "text": "The target is a member of a widespread fraternal organization.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [26, 26], "drawn": false, "name": "The target is a member of a widespread fraternal organization."}, {"_id": "woscp027", "type": "text", "text": "A long-standing rivalry exists between the client and the target, who will make a counter-offer against the client if captured.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [27, 27], "drawn": false, "name": "A long-standing rivalry exists between the client and the target, who will make a counter-offer against the client if captured."}, {"_id": "woscp028", "type": "text", "text": "The target has an identical twin, clones, or commonplace aesthetic remodelling.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [28, 28], "drawn": false, "name": "The target has an identical twin, clones, or commonplace aesthetic remodelling."}, {"_id": "woscp029", "type": "text", "text": "The target's crime was by order of a high-control group.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [29, 29], "drawn": false, "name": "The target's crime was by order of a high-control group."}, {"_id": "woscp030", "type": "text", "text": "The target has access to a jump-capable ship.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [30, 30], "drawn": false, "name": "The target has access to a jump-capable ship."}, {"_id": "woscp031", "type": "text", "text": "The target is tying up loose ends, hoping to go into hiding.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [31, 31], "drawn": false, "name": "The target is tying up loose ends, hoping to go into hiding."}, {"_id": "woscp032", "type": "text", "text": "The client and the target are secretly the same person.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [32, 32], "drawn": false, "name": "The client and the target are secretly the same person."}, {"_id": "woscp033", "type": "text", "text": "The bounty stipulates the recovery of a related item alongside the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [33, 33], "drawn": false, "name": "The bounty stipulates the recovery of a related item alongside the target."}, {"_id": "woscp034", "type": "text", "text": "The bounty requires the crew not to kill anyone through action or inaction.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [34, 34], "drawn": false, "name": "The bounty requires the crew not to kill anyone through action or inaction."}, {"_id": "woscp035", "type": "text", "text": "The instigating crime has a significant media following.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [35, 35], "drawn": false, "name": "The instigating crime has a significant media following."}, {"_id": "woscp036", "type": "text", "text": "Everyone is unwilling to discuss the crime, target or client.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [36, 36], "drawn": false, "name": "Everyone is unwilling to discuss the crime, target or client."}, {"_id": "woscp037", "type": "text", "text": "The target is a popular local celebrity.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [37, 37], "drawn": false, "name": "The target is a popular local celebrity."}, {"_id": "woscp038", "type": "text", "text": "The population despises the client.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [38, 38], "drawn": false, "name": "The population despises the client."}, {"_id": "woscp039", "type": "text", "text": "The population of the area is extremely hostile to all law enforcement, local or otherwise.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [39, 39], "drawn": false, "name": "The population of the area is extremely hostile to all law enforcement, local or otherwise."}, {"_id": "woscp040", "type": "text", "text": "The target has leverage over local forces and uses this to protect themselves.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [40, 40], "drawn": false, "name": "The target has leverage over local forces and uses this to protect themselves."}, {"_id": "woscp041", "type": "text", "text": "The client is unwilling or unable to pay the bounty reward.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [41, 41], "drawn": false, "name": "The client is unwilling or unable to pay the bounty reward."}, {"_id": "woscp042", "type": "text", "text": "The target plans another crime at a major local event.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [42, 42], "drawn": false, "name": "The target plans another crime at a major local event."}, {"_id": "woscp043", "type": "text", "text": "The target has evaded multiple bounty hunters.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [43, 43], "drawn": false, "name": "The target has evaded multiple bounty hunters."}, {"_id": "woscp044", "type": "text", "text": "The bounty is to provide plausible deniability. The client does not want to see the crew succeed.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [44, 44], "drawn": false, "name": "The bounty is to provide plausible deniability. The client does not want to see the crew succeed."}, {"_id": "woscp045", "type": "text", "text": "Upon the capture of the target, other parties try to bid on them.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [45, 45], "drawn": false, "name": "Upon the capture of the target, other parties try to bid on them."}, {"_id": "woscp046", "type": "text", "text": "The bounty requires no witnesses to the capture.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [46, 46], "drawn": false, "name": "The bounty requires no witnesses to the capture."}, {"_id": "woscp047", "type": "text", "text": "The client offers access to experimental tools or weapons.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [47, 47], "drawn": false, "name": "The client offers access to experimental tools or weapons."}, {"_id": "woscp048", "type": "text", "text": "A highly contagious disease ravages the body of the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [48, 48], "drawn": false, "name": "A highly contagious disease ravages the body of the target."}, {"_id": "woscp049", "type": "text", "text": "The area is famous for its deadly flora/fauna.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [49, 49], "drawn": false, "name": "The area is famous for its deadly flora/fauna."}, {"_id": "woscp050", "type": "text", "text": "The area is about to undergo a huge natural disaster.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [50, 50], "drawn": false, "name": "The area is about to undergo a huge natural disaster."}, {"_id": "woscp051", "type": "text", "text": "The location is under military occupation.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [51, 51], "drawn": false, "name": "The location is under military occupation."}, {"_id": "woscp052", "type": "text", "text": "The target has no digital footprint.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [52, 52], "drawn": false, "name": "The target has no digital footprint."}, {"_id": "woscp053", "type": "text", "text": "The target is a veteran, noted for their training in avoiding detection and capture.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [53, 53], "drawn": false, "name": "The target is a veteran, noted for their training in avoiding detection and capture."}, {"_id": "woscp054", "type": "text", "text": "A documentary series starring the target is currently being filmed.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [54, 54], "drawn": false, "name": "A documentary series starring the target is currently being filmed."}, {"_id": "woscp055", "type": "text", "text": "The client requires the crew to be filmed by a documentary crew throughout the process.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [55, 55], "drawn": false, "name": "The client requires the crew to be filmed by a documentary crew throughout the process."}, {"_id": "woscp056", "type": "text", "text": "The client only hires bounty hunters willing to undergo a certification process.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [56, 56], "drawn": false, "name": "The client only hires bounty hunters willing to undergo a certification process."}, {"_id": "woscp057", "type": "text", "text": "The family of the target is extensive and extremely loyal.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [57, 57], "drawn": false, "name": "The family of the target is extensive and extremely loyal."}, {"_id": "woscp058", "type": "text", "text": "The target has been hospitalized recently. The client is unaware.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [58, 58], "drawn": false, "name": "The target has been hospitalized recently. The client is unaware."}, {"_id": "woscp059", "type": "text", "text": "A major conference (or similar event) is the only known public appearance of the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [59, 59], "drawn": false, "name": "A major conference (or similar event) is the only known public appearance of the target."}, {"_id": "woscp060", "type": "text", "text": "The target is an avid collector of a rare and specific type of object.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [60, 60], "drawn": false, "name": "The target is an avid collector of a rare and specific type of object."}, {"_id": "woscp061", "type": "text", "text": "The bounty requires an entire group of perpetrators be captured.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [61, 61], "drawn": false, "name": "The bounty requires an entire group of perpetrators be captured."}, {"_id": "woscp062", "type": "text", "text": "The client wishes to see the target captured and humiliated in public.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [62, 62], "drawn": false, "name": "The client wishes to see the target captured and humiliated in public."}, {"_id": "woscp063", "type": "text", "text": "Beyond the bounty posting itself, there is no evidence of the client existing.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [63, 63], "drawn": false, "name": "Beyond the bounty posting itself, there is no evidence of the client existing."}, {"_id": "woscp064", "type": "text", "text": "The client intends to rescind the bounty and blackmail the crew into more ethically dubious work.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [64, 64], "drawn": false, "name": "The client intends to rescind the bounty and blackmail the crew into more ethically dubious work."}, {"_id": "woscp065", "type": "text", "text": "The target is widely reviled.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [65, 65], "drawn": false, "name": "The target is widely reviled."}, {"_id": "woscp066", "type": "text", "text": "The inherent nature of the location is inimical to life.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [66, 66], "drawn": false, "name": "The inherent nature of the location is inimical to life."}, {"_id": "woscp067", "type": "text", "text": "Unbeknown to all, the target is an android.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [67, 67], "drawn": false, "name": "Unbeknown to all, the target is an android."}, {"_id": "woscp068", "type": "text", "text": "The payment for the bounty is in goods and services.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [68, 68], "drawn": false, "name": "The payment for the bounty is in goods and services."}, {"_id": "woscp069", "type": "text", "text": "The crew has previously seen the target die.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [69, 69], "drawn": false, "name": "The crew has previously seen the target die."}, {"_id": "woscp070", "type": "text", "text": "The target believes themselves under magical protection.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [70, 70], "drawn": false, "name": "The target believes themselves under magical protection."}, {"_id": "woscp071", "type": "text", "text": "The target is hiding in an extremely dense urban environment.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [71, 71], "drawn": false, "name": "The target is hiding in an extremely dense urban environment."}, {"_id": "woscp072", "type": "text", "text": "The target is hiding in a desolate, underpopulated wilderness or rural environment.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [72, 72], "drawn": false, "name": "The target is hiding in a desolate, underpopulated wilderness or rural environment."}, {"_id": "woscp073", "type": "text", "text": "The target has a series of hardened safe houses, each with supplies and weapons.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [73, 73], "drawn": false, "name": "The target has a series of hardened safe houses, each with supplies and weapons."}, {"_id": "woscp074", "type": "text", "text": "The client requires they are present throughout the process. They require protection.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [74, 74], "drawn": false, "name": "The client requires they are present throughout the process. They require protection."}, {"_id": "woscp075", "type": "text", "text": "The target is trying to kill the client. If successful, there is no one to pay the crew.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [75, 75], "drawn": false, "name": "The target is trying to kill the client. If successful, there is no one to pay the crew."}, {"_id": "woscp076", "type": "text", "text": "The target would die before being taken alive.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [76, 76], "drawn": false, "name": "The target would die before being taken alive."}, {"_id": "woscp077", "type": "text", "text": "The associates of the target will seek revenge for any harm.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [77, 77], "drawn": false, "name": "The associates of the target will seek revenge for any harm."}, {"_id": "woscp078", "type": "text", "text": "The target is heavily involved in a popular, pro-social cause. Without them the efforts are likely to fail.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [78, 78], "drawn": false, "name": "The target is heavily involved in a popular, pro-social cause. Without them the efforts are likely to fail."}, {"_id": "woscp079", "type": "text", "text": "The target is charismatic. They inspire extreme loyalty.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [79, 79], "drawn": false, "name": "The target is charismatic. They inspire extreme loyalty."}, {"_id": "woscp080", "type": "text", "text": "85% of the target's body has been cybernetically enhanced.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [80, 80], "drawn": false, "name": "85% of the target's body has been cybernetically enhanced."}, {"_id": "woscp081", "type": "text", "text": "The target has planted false rumours and red herrings as to their own location.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [81, 81], "drawn": false, "name": "The target has planted false rumours and red herrings as to their own location."}, {"_id": "woscp082", "type": "text", "text": "The target is always outlandishly dressed and highly recognizable.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [82, 82], "drawn": false, "name": "The target is always outlandishly dressed and highly recognizable."}, {"_id": "woscp083", "type": "text", "text": "The target has moles in the client's organization.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [83, 83], "drawn": false, "name": "The target has moles in the client's organization."}, {"_id": "woscp084", "type": "text", "text": "This bounty is a job interview for the real bounty.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [84, 84], "drawn": false, "name": "This bounty is a job interview for the real bounty."}, {"_id": "woscp085", "type": "text", "text": "The client needs the target for a human sacrifice.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [85, 85], "drawn": false, "name": "The client needs the target for a human sacrifice."}, {"_id": "woscp086", "type": "text", "text": "The target is the final living witness of something terrible.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [86, 86], "drawn": false, "name": "The target is the final living witness of something terrible."}, {"_id": "woscp087", "type": "text", "text": "The target is an experimental subject or specimen. The bounty is a cover for their return.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [87, 87], "drawn": false, "name": "The target is an experimental subject or specimen. The bounty is a cover for their return."}, {"_id": "woscp088", "type": "text", "text": "The target holds huge debts. The debtors try to collect any outstanding debt from the killers.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [88, 88], "drawn": false, "name": "The target holds huge debts. The debtors try to collect any outstanding debt from the killers."}, {"_id": "woscp089", "type": "text", "text": "The target has the ability to feign death.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [89, 89], "drawn": false, "name": "The target has the ability to feign death."}, {"_id": "woscp090", "type": "text", "text": "The target had powerful dreams of a strange entity, ethereal yet heavy. They have made a pact with this being.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [90, 90], "drawn": false, "name": "The target had powerful dreams of a strange entity, ethereal yet heavy. They have made a pact with this being."}, {"_id": "woscp091", "type": "text", "text": "The target habitually marks their passing in an idiosyncratic way.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [91, 91], "drawn": false, "name": "The target habitually marks their passing in an idiosyncratic way."}, {"_id": "woscp092", "type": "text", "text": "Local law enforcement protects the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [92, 92], "drawn": false, "name": "Local law enforcement protects the target."}, {"_id": "woscp093", "type": "text", "text": "The target is a high level employee at a major local corporation.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [93, 93], "drawn": false, "name": "The target is a high level employee at a major local corporation."}, {"_id": "woscp094", "type": "text", "text": "A major union organiser, the wider organization protects the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [94, 94], "drawn": false, "name": "A major union organiser, the wider organization protects the target."}, {"_id": "woscp095", "type": "text", "text": "A member of the largest local criminal organization is closely related to the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [95, 95], "drawn": false, "name": "A member of the largest local criminal organization is closely related to the target."}, {"_id": "woscp096", "type": "text", "text": "The target curses their slayer or captor.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [96, 96], "drawn": false, "name": "The target curses their slayer or captor."}, {"_id": "woscp097", "type": "text", "text": "The influence of a local politician protects the target. The two are old friends.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [97, 97], "drawn": false, "name": "The influence of a local politician protects the target. The two are old friends."}, {"_id": "woscp098", "type": "text", "text": "The target does not eat. They feed upon the dreams of others, projecting their hunger outwards as a spectral maw.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [98, 98], "drawn": false, "name": "The target does not eat. They feed upon the dreams of others, projecting their hunger outwards as a spectral maw."}, {"_id": "woscp099", "type": "text", "text": "The target is convinced their capture or death would doom worlds.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [99, 99], "drawn": false, "name": "The target is convinced their capture or death would doom worlds."}, {"_id": "woscp100", "type": "text", "text": "The target is no more. Something has consumed them, and now wears their likeness as a skin-suit. They move among their prey once more.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [100, 100], "drawn": false, "name": "The target is no more. Something has consumed them, and now wears their likeness as a skin-suit. They move among their prey once more."}], "flags": {}, "folder": null, "sort": 1300, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}}
