/equipment/mag_boots.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.uHPFcNQEA0amUJQJ", "weight": 1, "range": [6, 6], "drawn": false}, {"_id": "wosT07a1", "type": "document", "name": "Hazard Suit", "img": "modules/fvtt_mosh_1e_psg/icons/armor/hazard_suit.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_armor_1e.Item.4JPx0B6TxGYR7kiS", "weight": 1, "range": [7, 7], "drawn": false}, {"_id": "wosT07a2", "type": "document", "name": "Rigging Gun", "img": "modules/fvtt_mosh_1e_psg/icons/weapons/rigging_gun.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_weapons_1e.Item.7raxWeN6uB7p6ZCI", "weight": 1, "range": [7, 7], "drawn": false}, {"_id": "wosT07a3", "type": "document", "name": "Bioscanner", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/bioscanner.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.vBCc1NR9KyGy0eci", "weight": 1, "range": [7, 7], "drawn": false}, {"_id": "wosT08a1", "type": "document", "name": "Vaccsuit", "img": "modules/fvtt_mosh_1e_psg/icons/armor/vaccsuit.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_armor_1e.Item.MW8GRF9grFvsAGcR", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "wosT08a2", "type": "document", "name": "Crowbar", "img": "modules/fvtt_mosh_1e_psg/icons/weapons/crowbar.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_weapons_1e.Item.1fpZrZ5uN7Ad9XvX", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "wosT08a3", "type": "document", "name": "Explosives & Detonator", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/explosives_&_detonator.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.u2rWP6CUonlVFx8F", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "wosT08a4", "type": "document", "name": "Lockpick Set", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/lockpick_set.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.GPeQpFIBuQIrKzX0", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "wosT08a5", "type": "document", "name": "Mag-boots", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/mag_boots.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_equipment_1e.Item.uHPFcNQEA0amUJQJ", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "wosT09a1", "type": "document", "name": "Standard Crew Attire", "img": "modules/fvtt_mosh_1e_psg/icons/armor/standard_crew_attire.png", "documentUuid": "Compendium.fvtt_mosh_1e_psg.items_armor_1e.Item.2NoJYxUEvxCLk58f", "weight": 1, "range": [9, 9], "drawn": false}, {"_id": "wosT09a2", "type": "document", "name": "Obsolete Exoloader", "img": "modules/fvtt_mosh_1e_psg/icons/equipment/exoloader.png", "documentUuid": "Compendium.mosh-wos-items.wos_equipment.Item.WoSEquipObsExoload", "weight": 1, "range": [9, 9], "drawn": false}], "flags": {}, "folder": null, "sort": 400, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}, "schemaVersion": "13.341"}
{"_id": "WoSPatchBH0001", "name": "Bounty Hunter Patch Table", "img": "icons/svg/d6-grey.svg", "description": "<p>Roll on this table for a Bounty Hunter's starting patch.</p>", "formula": "1d6", "replacement": true, "displayRoll": true, "results": [{"_id": "WoSPTBHR0000001", "type": "document", "name": "\"Dead or Alive (Preferably Alive)\" Patch", "img": "", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000001", "weight": 1, "range": [1, 1], "drawn": false}, {"_id": "WoSPTBHR0000002", "type": "document", "name": "Warrant Officer Badge (Faded, Unofficial)", "img": "", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000002", "weight": 1, "range": [2, 2], "drawn": false}, {"_id": "WoSPTBHR0000003", "type": "document", "name": "Colonial Bounty Registry Logo Patch", "img": "", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000003", "weight": 1, "range": [3, 3], "drawn": false}, {"_id": "WoSPTBHR0000004", "type": "document", "name": "\"I Found Him\" Patch (Crossed-Out Skull)", "img": "", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000004", "weight": 1, "range": [4, 4], "drawn": false}, {"_id": "WoSPTBHR0000005", "type": "document", "name": "Sector 7 Fugitive Recovery Unit Patch", "img": "", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000005", "weight": 1, "range": [5, 5], "drawn": false}, {"_id": "WoSPTBHR0000006", "type": "document", "name": "\"Payment Upon Delivery\" (Crossed Keys)", "img": "", "documentUuid": "Compendium.mosh-wos-items.wos_patches.Item.WoSPatch00000006", "weight": 1, "range": [6, 6], "drawn": false}], "flags": {}, "folder": null, "sort": 800, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}, "schemaVersion": "13.341"}
{"_id": "WoSTableBountyLevel", "name": "Wages of Sin - Bounty Level & Rewards", "img": "icons/svg/d20-black.svg", "description": "<p>Bounty Level & Rewards table from Wages of Sin (pg. 12-13).</p>", "formula": "1d9", "replacement": true, "displayRoll": true, "results": [{"_id": "blr01", "type": "text", "name": "BL:1 - Minor Bounties (Payscale: 1D10KCR) - Minor issues for organizations. Big problems for desperate civilians.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [1, 1], "drawn": false}, {"_id": "blr02", "type": "text", "name": "BL:2 - Lesser Bounties (Payscale: 1D5X10KCR) - Bounties on people who do not want to be found.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [2, 2], "drawn": false}, {"_id": "blr03", "type": "text", "name": "BL:3 - Serious Bounties (Payscale: 1D10X10KCR) - Targets with experience or resources and the will to use them.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [3, 3], "drawn": false}, {"_id": "blr04", "type": "text", "name": "BL:4 - Dangerous Bounties (Payscale: 1D5X100KCR) - Targets with experience and resources. They will kill you.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [4, 4], "drawn": false}, {"_id": "blr05", "type": "text", "name": "BL:5 - Major Bounties (Payscale: 1D10X100KCR) - High-power targets or those outside normal social context.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [5, 5], "drawn": false}, {"_id": "blr06", "type": "text", "name": "BL:6 - Operational Bounties (Payscale: 1D5MCR) - Those protected by organized violence.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [6, 6], "drawn": false}, {"_id": "blr07", "type": "text", "name": "BL:7 - Strategic Bounties (Payscale: 1D10MCR) - The linchpins of organizations or those who wield terrible power directly.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [7, 7], "drawn": false}, {"_id": "blr08", "type": "text", "name": "BL:8 - Legendary Bounties (Payscale: 2D10MCR) - Household names or those at the secret loci of power.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "blr09", "type": "text", "name": "BL:9 - Apocalyptic Bounties (Payscale: 1D100MCR) - Names that are only whispered. Senior executives. Rogue AI.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [9, 9], "drawn": false}], "flags": {}, "folder": null, "sort": 1000, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}, "schemaVersion": "13.341"}
{"_id": "WoSTableClientType", "name": "Wages of Sin - Client Type", "img": "icons/svg/d20-black.svg", "description": "<p>Table 20.1 Client Type table from Wages of Sin.</p>", "formula": "1d10", "replacement": true, "displayRoll": true, "results": [{"_id": "wosct01", "type": "text", "name": "Corporate", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [1, 4], "drawn": false}, {"_id": "wosct02", "type": "text", "name": "Criminal", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [5, 6], "drawn": false}, {"_id": "wosct03", "type": "text", "name": "Union", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [7, 7], "drawn": false}, {"_id": "wosct04", "type": "text", "name": "Civilian", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "wosct05", "type": "text", "name": "Military", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [9, 10], "drawn": false}], "flags": {}, "folder": null, "sort": 1100, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}, "schemaVersion": "13.341"}
{"_id": "WoSTableComplications", "name": "Wages of Sin - Complications", "img": "icons/svg/d20-black.svg", "description": "<p>Complications table (d100) from Wages of Sin.</p>", "formula": "1d100", "replacement": true, "displayRoll": true, "results": [{"_id": "woscp001", "type": "text", "name": "There is a family or personal relationship between the client and the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [1, 1], "drawn": false}, {"_id": "woscp002", "type": "text", "name": "A local authority has imprisoned the target for unrelated crimes.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [2, 2], "drawn": false}, {"_id": "woscp003", "type": "text", "name": "The target lives nomadically, with no fixed address.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [3, 3], "drawn": false}, {"_id": "woscp004", "type": "text", "name": "The target has extensive combat training.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [4, 4], "drawn": false}, {"_id": "woscp005", "type": "text", "name": "The target is in an active or imminent war zone.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [5, 5], "drawn": false}, {"_id": "woscp006", "type": "text", "name": "The target has an extensive network of friends in the area.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [6, 6], "drawn": false}, {"_id": "woscp007", "type": "text", "name": "A religious organization protects the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [7, 7], "drawn": false}, {"_id": "woscp008", "type": "text", "name": "The target is not guilty of the crime. They know who is.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "woscp009", "type": "text", "name": "The client is attempting to pin a crime on the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [9, 9], "drawn": false}, {"_id": "woscp010", "type": "text", "name": "An unknown force protects the target. They are unaware.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [10, 10], "drawn": false}, {"_id": "woscp011", "type": "text", "name": "The target is embroiled in an unrelated sensitive legal matter which requires their full attention.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [11, 11], "drawn": false}, {"_id": "woscp012", "type": "text", "name": "The crew already knows the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [12, 12], "drawn": false}, {"_id": "woscp013", "type": "text", "name": "The client is many jumps away from the target and requires delivery.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [13, 13], "drawn": false}, {"_id": "woscp014", "type": "text", "name": "Other victims pursue the target, seeking revenge for themselves.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [14, 14], "drawn": false}, {"_id": "woscp015", "type": "text", "name": "The target is able to morally justify their actions.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [15, 15], "drawn": false}, {"_id": "woscp016", "type": "text", "name": "The target is unaware of their 'crime' or the bounty.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [16, 16], "drawn": false}, {"_id": "woscp017", "type": "text", "name": "The client is using the bounty as cover to pursue an unrelated agenda.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [17, 17], "drawn": false}, {"_id": "woscp018", "type": "text", "name": "The target protects themselves with their immense wealth.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [18, 18], "drawn": false}, {"_id": "woscp019", "type": "text", "name": "Scant details on the target are available; significant investigative legwork is required.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [19, 19], "drawn": false}, {"_id": "woscp020", "type": "text", "name": "The target has many dependents.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [20, 20], "drawn": false}, {"_id": "woscp021", "type": "text", "name": "The bounty has a strict, short time limit.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [21, 21], "drawn": false}, {"_id": "woscp022", "type": "text", "name": "The lives of bystanders mean nothing to the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [22, 22], "drawn": false}, {"_id": "woscp023", "type": "text", "name": "Something inhuman pursues the target. It will not allow others to seize its quarry.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [23, 23], "drawn": false}, {"_id": "woscp024", "type": "text", "name": "Prophetic visions plague the target. These visions are infectious, spreading to any in close physical proximity.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [24, 24], "drawn": false}, {"_id": "woscp025", "type": "text", "name": "The target is willing to trade valuable information for their freedom.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [25, 25], "drawn": false}, {"_id": "woscp026", "type": "text", "name": "The target is a member of a widespread fraternal organization.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [26, 26], "drawn": false}, {"_id": "woscp027", "type": "text", "name": "A long-standing rivalry exists between the client and the target, who will make a counter-offer against the client if captured.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [27, 27], "drawn": false}, {"_id": "woscp028", "type": "text", "name": "The target has an identical twin, clones, or commonplace aesthetic remodelling.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [28, 28], "drawn": false}, {"_id": "woscp029", "type": "text", "name": "The target's crime was by order of a high-control group.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [29, 29], "drawn": false}, {"_id": "woscp030", "type": "text", "name": "The target has access to a jump-capable ship.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [30, 30], "drawn": false}, {"_id": "woscp031", "type": "text", "name": "The target is tying up loose ends, hoping to go into hiding.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [31, 31], "drawn": false}, {"_id": "woscp032", "type": "text", "name": "The client and the target are secretly the same person.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [32, 32], "drawn": false}, {"_id": "woscp033", "type": "text", "name": "The bounty stipulates the recovery of a related item alongside the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [33, 33], "drawn": false}, {"_id": "woscp034", "type": "text", "name": "The bounty requires the crew not to kill anyone through action or inaction.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [34, 34], "drawn": false}, {"_id": "woscp035", "type": "text", "name": "The instigating crime has a significant media following.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [35, 35], "drawn": false}, {"_id": "woscp036", "type": "text", "name": "Everyone is unwilling to discuss the crime, target or client.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [36, 36], "drawn": false}, {"_id": "woscp037", "type": "text", "name": "The target is a popular local celebrity.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [37, 37], "drawn": false}, {"_id": "woscp038", "type": "text", "name": "The population despises the client.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [38, 38], "drawn": false}, {"_id": "woscp039", "type": "text", "name": "The population of the area is extremely hostile to all law enforcement, local or otherwise.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [39, 39], "drawn": false}, {"_id": "woscp040", "type": "text", "name": "The target has leverage over local forces and uses this to protect themselves.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [40, 40], "drawn": false}, {"_id": "woscp041", "type": "text", "name": "The client is unwilling or unable to pay the bounty reward.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [41, 41], "drawn": false}, {"_id": "woscp042", "type": "text", "name": "The target plans another crime at a major local event.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [42, 42], "drawn": false}, {"_id": "woscp043", "type": "text", "name": "The target has evaded multiple bounty hunters.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [43, 43], "drawn": false}, {"_id": "woscp044", "type": "text", "name": "The bounty is to provide plausible deniability. The client does not want to see the crew succeed.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [44, 44], "drawn": false}, {"_id": "woscp045", "type": "text", "name": "Upon the capture of the target, other parties try to bid on them.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [45, 45], "drawn": false}, {"_id": "woscp046", "type": "text", "name": "The bounty requires no witnesses to the capture.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [46, 46], "drawn": false}, {"_id": "woscp047", "type": "text", "name": "The client offers access to experimental tools or weapons.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [47, 47], "drawn": false}, {"_id": "woscp048", "type": "text", "name": "A highly contagious disease ravages the body of the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [48, 48], "drawn": false}, {"_id": "woscp049", "type": "text", "name": "The area is famous for its deadly flora/fauna.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [49, 49], "drawn": false}, {"_id": "woscp050", "type": "text", "name": "The area is about to undergo a huge natural disaster.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [50, 50], "drawn": false}, {"_id": "woscp051", "type": "text", "name": "The location is under military occupation.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [51, 51], "drawn": false}, {"_id": "woscp052", "type": "text", "name": "The target has no digital footprint.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [52, 52], "drawn": false}, {"_id": "woscp053", "type": "text", "name": "The target is a veteran, noted for their training in avoiding detection and capture.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [53, 53], "drawn": false}, {"_id": "woscp054", "type": "text", "name": "A documentary series starring the target is currently being filmed.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [54, 54], "drawn": false}, {"_id": "woscp055", "type": "text", "name": "The client requires the crew to be filmed by a documentary crew throughout the process.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [55, 55], "drawn": false}, {"_id": "woscp056", "type": "text", "name": "The client only hires bounty hunters willing to undergo a certification process.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [56, 56], "drawn": false}, {"_id": "woscp057", "type": "text", "name": "The family of the target is extensive and extremely loyal.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [57, 57], "drawn": false}, {"_id": "woscp058", "type": "text", "name": "The target has been hospitalized recently. The client is unaware.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [58, 58], "drawn": false}, {"_id": "woscp059", "type": "text", "name": "A major conference (or similar event) is the only known public appearance of the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [59, 59], "drawn": false}, {"_id": "woscp060", "type": "text", "name": "The target is an avid collector of a rare and specific type of object.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [60, 60], "drawn": false}, {"_id": "woscp061", "type": "text", "name": "The bounty requires an entire group of perpetrators be captured.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [61, 61], "drawn": false}, {"_id": "woscp062", "type": "text", "name": "The client wishes to see the target captured and humiliated in public.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [62, 62], "drawn": false}, {"_id": "woscp063", "type": "text", "name": "Beyond the bounty posting itself, there is no evidence of the client existing.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [63, 63], "drawn": false}, {"_id": "woscp064", "type": "text", "name": "The client intends to rescind the bounty and blackmail the crew into more ethically dubious work.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [64, 64], "drawn": false}, {"_id": "woscp065", "type": "text", "name": "The target is widely reviled.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [65, 65], "drawn": false}, {"_id": "woscp066", "type": "text", "name": "The inherent nature of the location is inimical to life.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [66, 66], "drawn": false}, {"_id": "woscp067", "type": "text", "name": "Unbeknown to all, the target is an android.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [67, 67], "drawn": false}, {"_id": "woscp068", "type": "text", "name": "The payment for the bounty is in goods and services.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [68, 68], "drawn": false}, {"_id": "woscp069", "type": "text", "name": "The crew has previously seen the target die.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [69, 69], "drawn": false}, {"_id": "woscp070", "type": "text", "name": "The target believes themselves under magical protection.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [70, 70], "drawn": false}, {"_id": "woscp071", "type": "text", "name": "The target is hiding in an extremely dense urban environment.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [71, 71], "drawn": false}, {"_id": "woscp072", "type": "text", "name": "The target is hiding in a desolate, underpopulated wilderness or rural environment.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [72, 72], "drawn": false}, {"_id": "woscp073", "type": "text", "name": "The target has a series of hardened safe houses, each with supplies and weapons.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [73, 73], "drawn": false}, {"_id": "woscp074", "type": "text", "name": "The client requires they are present throughout the process. They require protection.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [74, 74], "drawn": false}, {"_id": "woscp075", "type": "text", "name": "The target is trying to kill the client. If successful, there is no one to pay the crew.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [75, 75], "drawn": false}, {"_id": "woscp076", "type": "text", "name": "The target would die before being taken alive.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [76, 76], "drawn": false}, {"_id": "woscp077", "type": "text", "name": "The associates of the target will seek revenge for any harm.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [77, 77], "drawn": false}, {"_id": "woscp078", "type": "text", "name": "The target is heavily involved in a popular, pro-social cause. Without them the efforts are likely to fail.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [78, 78], "drawn": false}, {"_id": "woscp079", "type": "text", "name": "The target is charismatic. They inspire extreme loyalty.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [79, 79], "drawn": false}, {"_id": "woscp080", "type": "text", "name": "85% of the target's body has been cybernetically enhanced.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [80, 80], "drawn": false}, {"_id": "woscp081", "type": "text", "name": "The target has planted false rumours and red herrings as to their own location.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [81, 81], "drawn": false}, {"_id": "woscp082", "type": "text", "name": "The target is always outlandishly dressed and highly recognizable.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [82, 82], "drawn": false}, {"_id": "woscp083", "type": "text", "name": "The target has moles in the client's organization.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [83, 83], "drawn": false}, {"_id": "woscp084", "type": "text", "name": "This bounty is a job interview for the real bounty.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [84, 84], "drawn": false}, {"_id": "woscp085", "type": "text", "name": "The client needs the target for a human sacrifice.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [85, 85], "drawn": false}, {"_id": "woscp086", "type": "text", "name": "The target is the final living witness of something terrible.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [86, 86], "drawn": false}, {"_id": "woscp087", "type": "text", "name": "The target is an experimental subject or specimen. The bounty is a cover for their return.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [87, 87], "drawn": false}, {"_id": "woscp088", "type": "text", "name": "The target holds huge debts. The debtors try to collect any outstanding debt from the killers.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [88, 88], "drawn": false}, {"_id": "woscp089", "type": "text", "name": "The target has the ability to feign death.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [89, 89], "drawn": false}, {"_id": "woscp090", "type": "text", "name": "The target had powerful dreams of a strange entity, ethereal yet heavy. They have made a pact with this being.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [90, 90], "drawn": false}, {"_id": "woscp091", "type": "text", "name": "The target habitually marks their passing in an idiosyncratic way.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [91, 91], "drawn": false}, {"_id": "woscp092", "type": "text", "name": "Local law enforcement protects the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [92, 92], "drawn": false}, {"_id": "woscp093", "type": "text", "name": "The target is a high level employee at a major local corporation.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [93, 93], "drawn": false}, {"_id": "woscp094", "type": "text", "name": "A major union organiser, the wider organization protects the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [94, 94], "drawn": false}, {"_id": "woscp095", "type": "text", "name": "A member of the largest local criminal organization is closely related to the target.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [95, 95], "drawn": false}, {"_id": "woscp096", "type": "text", "name": "The target curses their slayer or captor.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [96, 96], "drawn": false}, {"_id": "woscp097", "type": "text", "name": "The influence of a local politician protects the target. The two are old friends.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [97, 97], "drawn": false}, {"_id": "woscp098", "type": "text", "name": "The target does not eat. They feed upon the dreams of others, projecting their hunger outwards as a spectral maw.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [98, 98], "drawn": false}, {"_id": "woscp099", "type": "text", "name": "The target is convinced their capture or death would doom worlds.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [99, 99], "drawn": false}, {"_id": "woscp100", "type": "text", "name": "The target is no more. Something has consumed them, and now wears their likeness as a skin-suit. They move among their prey once more.", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [100, 100], "drawn": false}], "flags": {}, "folder": null, "sort": 1300, "_stats": {"systemId": "mosh", "systemVersion": "0.6.1", "coreVersion": "14", "createdTime": 1753101600000, "modifiedTime": 1753101600000, "lastModifiedBy": "wos_module_init"}, "schemaVersion": "13.341"}
{"_id": "WoSTableCrime", "name": "Wages of Sin - Crime", "img": "icons/svg/d20-black.svg", "description": "<p>Table 20.2 & 21.2 Crime table from Wages of Sin.</p>", "formula": "1d100", "replacement": true, "displayRoll": true, "results": [{"_id": "woscr001", "type": "text", "name": "Theft", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [1, 1], "drawn": false}, {"_id": "woscr002", "type": "text", "name": "Theft", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [2, 2], "drawn": false}, {"_id": "woscr003", "type": "text", "name": "Arson", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [3, 3], "drawn": false}, {"_id": "woscr004", "type": "text", "name": "Arson", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [4, 4], "drawn": false}, {"_id": "woscr005", "type": "text", "name": "Espionage", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [5, 5], "drawn": false}, {"_id": "woscr006", "type": "text", "name": "Espionage", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [6, 6], "drawn": false}, {"_id": "woscr007", "type": "text", "name": "Sabotage", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [7, 7], "drawn": false}, {"_id": "woscr008", "type": "text", "name": "Sabotage", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [8, 8], "drawn": false}, {"_id": "woscr009", "type": "text", "name": "Thoughtcrime", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [9, 9], "drawn": false}, {"_id": "woscr010", "type": "text", "name": "Thoughtcrime", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [10, 10], "drawn": false}, {"_id": "woscr011", "type": "text", "name": "Unregistered Union Activity", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [11, 11], "drawn": false}, {"_id": "woscr012", "type": "text", "name": "Unregistered Union Activity", "img": "icons/svg/d20-black.svg", "weight": 1, "range": [12, 12], "drawn": false}, {"_id": "woscr013", "type": "text", "name": "Revealing Protected Informatio