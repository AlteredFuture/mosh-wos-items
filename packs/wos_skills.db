{"_id":"WoSSkillInterrog01","name":"Interrogation","type":"skill","img":"modules/fvtt_mosh_1e_psg/icons/skills/psychology.png","system":{"description":"<p>Extracting information from unwilling subjects through psychological pressure, strategic deception, or physical leverage. Know when to push, and when to let silence do the work.</p>","rank":"Trained","bonus":10,"prerequisite_ids":[]},"effects":[],"flags":{},"folder":null,"sort":0,"_stats":{"systemId":"mosh","systemVersion":"0.6.1","coreVersion":"14","createdTime":1753101600000,"modifiedTime":1753101600000,"lastModifiedBy":"wos_module_init"}}
{"_id":"WoSSkillJointMnp1","name":"Joint Manipulation/Submission","type":"skill","img":"modules/fvtt_mosh_1e_psg/icons/skills/hand_to_hand_combat.png","system":{"description":"<p>Specialised grappling techniques for restraining, incapacitating, or subduing a target without lethal force. Includes joint locks, choke holds, pressure points, and takedowns. When used to subdue a target alive, Combat Checks are made at [+].</p>","rank":"Expert","bonus":15,"prerequisite_ids":["Compendium.fvtt_mosh_1e_psg.items_skills_1e.Item.30dSaZxJc40A9V5r"]},"effects":[],"flags":{},"folder":null,"sort":0,"_stats":{"systemId":"mosh","systemVersion":"0.6.1","coreVersion":"14","createdTime":1753101600000,"modifiedTime":1753101600000,"lastModifiedBy":"wos_module_init"}}
{"_id":"WoSSkillMartialArt","name":"Martial Arts","type":"skill","img":"modules/fvtt_mosh_1e_psg/icons/skills/hand_to_hand_combat.png","system":{"description":"<p>Advanced mastery of unarmed combat, strike counters, and defensive maneuvers. Unarmed attacks inflict +1d5 damage and Combat Checks made unarmed are rolled at [+].</p>","rank":"Master","bonus":20,"prerequisite_ids":["Compendium.fvtt_mosh_1e_psg.items_skills_1e.Item.30dSaZxJc40A9V5r"]},"effects":[],"flags":{},"folder":null,"sort":0,"_stats":{"systemId":"mosh","systemVersion":"0.6.1","coreVersion":"14","createdTime":1753101600000,"modifiedTime":1753101600000,"lastModifiedBy":"wos_module_init"}}
{"_id":"WoSSkillSurveill01","name":"Surveillance","type":"skill","img":"modules/fvtt_mosh_1e_psg/icons/skills/computers.png","system":{"description":"<p>The operation and exploitation of sensor networks, body cams, and electronic eavesdropping equipment. Includes counter-surveillance detection.</p>","rank":"Expert","bonus":15,"prerequisite_ids":["Compendium.mosh-wos-items.wos_skills.Item.WoSSkillTracking01"]},"effects":[],"flags":{},"folder":null,"sort":0,"_stats":{"systemId":"mosh","systemVersion":"0.6.1","coreVersion":"14","createdTime":1753101600000,"modifiedTime":1753101600000,"lastModifiedBy":"wos_module_init"}}
{"_id":"WoSSkillTracking01","name":"Tracking","type":"skill","img":"modules/fvtt_mosh_1e_psg/icons/skills/wilderness_survival.png","system":{"description":"<p>The ability to follow a target's trail across environments — urban sprawl, station corridors, or open terrain. Includes reading surveillance data and informant networks.</p>","rank":"Trained","bonus":10,"prerequisite_ids":[]},"effects":[],"flags":{},"folder":null,"sort":0,"_stats":{"systemId":"mosh","systemVersion":"0.6.1","coreVersion":"14","createdTime":1753101600000,"modifiedTime":1753101600000,"lastModifiedBy":"wos_module_init"}}
